{
	"name": "wp-dependency-manager",
	"version": "0.0.1",
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"build": "turbo run build",
		"build:plugin": "turbo run build --filter=base-plugin",
		"build:theme": "turbo run build --filter=base-theme",
		"start": "turbo run start --parallel",
		"start:plugin": "turbo run start --filter=base-plugin",
		"start:theme": "turbo run start --filter=base-theme",
		"lint": "pnpm run lint:plugin && pnpm run lint:theme",
		"lint:plugin": "pnpm run lint:plugin-js && pnpm run lint:plugin-css && pnpm run lint:plugin-php",
		"lint:plugin-js": "wp-scripts lint-js ./wordpress/wp-content/plugins/base-plugin/src",
		"lint:plugin-css": "stylelint \"./wordpress/wp-content/plugins/base-plugin/**/*.{css,scss}\"",
		"lint:plugin-php": "composer lint-plugin-php",
		"lint:theme": "pnpm run lint:theme-js && pnpm run lint:theme-css && pnpm run lint:theme-php",
		"lint:theme-js": "wp-scripts lint-js ./wordpress/wp-content/themes/base-theme/src",
		"lint:theme-css": "stylelint \"./wordpress/wp-content/themes/base-theme/**/*.{css,scss}\"",
		"lint:theme-php": "composer lint-theme-php",
		"format": "pnpm run format:plugin && pnpm run format:theme",
		"format:plugin": "pnpm run format:plugin-js && pnpm run format:plugin-css && pnpm run format:plugin-php",
		"format:plugin-js": "wp-scripts lint-js ./wordpress/wp-content/plugins/base-plugin/src --fix",
		"format:plugin-css": "stylelint \"./wordpress/wp-content/plugins/base-plugin/**/*.{css,scss}\" --fix",
		"format:plugin-php": "composer format-plugin-php",
		"format:theme": "pnpm run format:theme-js && pnpm run format:theme-css && pnpm run format:theme-php",
		"format:theme-js": "wp-scripts lint-js ./wordpress/wp-content/themes/base-theme/src --fix",
		"format:theme-css": "stylelint \"./wordpress/wp-content/themes/base-theme/**/*.{css,scss}\" --fix",
		"format:theme-php": "composer format-theme-php",
		"clean": "turbo run clean && rm -rf .turbo node_modules",
		"clean:fresh": "rm -rf .turbo node_modules pnpm-lock.yaml && turbo run clean && pnpm install && pnpm run build",
		"clean:plugin": "turbo run clean --filter=base-plugin",
		"clean:theme": "turbo run clean --filter=base-theme",
		"prepare": "husky"
	},
	"devDependencies": {
		"@wordpress/blocks": "^14.10.0",
		"@wordpress/data": "^10.21.0",
		"@wordpress/dom-ready": "^4.21.0",
		"@wordpress/element": "^6.21.0",
		"@wordpress/eslint-plugin": "22.11.0",
		"@wordpress/i18n": "^5.21.0",
		"@wordpress/icons": "^10.21.0",
		"@wordpress/interactivity": "^6.21.0",
		"@wordpress/scripts": "30.18.0",
		"concurrently": "^9.1.2",
		"husky": "9.1.7",
		"lint-staged": "^16.2.7",
		"postcss-import": "^16.1.0",
		"prettier": "3.5.3",
		"stylelint": "16.20.0",
		"stylelint-scss": "^6.11.1",
		"turbo": "2.5.4",
		"webpack": "^5.98.0",
		"webpack-bundle-analyzer": "^4.10.2",
		"webpack-cli": "^6.0.1"
	},
	"lint-staged": {
		"wordpress/wp-content/plugins/base-plugin/src/**/*.{css,scss}": "stylelint --fix",
		"wordpress/wp-content/themes/base-theme/src/**/*.{css,scss}": "stylelint --fix",
		"wordpress/wp-content/plugins/base-plugin/src/**/*.js": [
			"wp-scripts format",
			"wp-scripts lint-js"
		],
		"wordpress/wp-content/themes/base-theme/src/**/*.js": [
			"wp-scripts format",
			"wp-scripts lint-js"
		],
		"wordpress/wp-content/plugins/base-plugin/{plugin.php,Functions/**/*.php,src/**/*.php}": "./vendor/bin/phpcs --standard=phpcs.xml.dist",
		"wordpress/wp-content/themes/base-theme/{functions.php,Functions/**/*.php,*.php}": "./vendor/bin/phpcs --standard=phpcs.xml.dist"
	}
}
